# No compartas esta clave en chats, repositorios ni capturas.
OPENAI_API_KEY=pon_aqui_tu_api_key

# Modelo recomendado para empezar barato.
OPENAI_MODEL_CHAT=gpt-5.4-mini
OPENAI_MODEL_EVALUATION=gpt-5.4-mini

# Protección de gasto: máximo de mensajes del estudiante por sesión.
MAX_STUDENT_MESSAGES=35
